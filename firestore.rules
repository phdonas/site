rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Visitantes podem criar leads (coleta de e-mail para recursos gratuitos)
    match /leads/{document} {
      allow create: if true;
    }

    // Todo o restante: leitura pública, escrita só para admin autenticado
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
